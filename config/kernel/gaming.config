# NovaForge OS Kernel Configuration
# Gaming-optimized kernel settings

# Kernel version
KERNEL_VERSION="6.7.0"
KERNEL_FLAVOR="gaming"

# Compilation settings
CONFIG_CC_OPTIMIZE_3=y
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
CONFIG_CC_OPTIMIZE_FOR_SIZE=n

# Gaming & low-latency
CONFIG_NO_HZ=y
CONFIG_NO_HZ_IDLE=y
CONFIG_NO_HZ_FULL=y
CONFIG_HZ_300=y
CONFIG_HZ=300
CONFIG_SCHED_MONITOR=y
CONFIG_SCHED_TRACTIVE=y

# Preempt
CONFIG_PREEMPT=y
CONFIG_PREEMPT_VOLUNTARY=y
CONFIG_PREEMPT_BUILD=y

# CPU governor
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y

# Timer
CONFIG_HIGH_RES_TIMERS=y
CONFIG_HPET_TIMER=y

# Gaming latency
CONFIG_RTC_MC146208=n
CONFIG_HPET=y
CONFIG_HPET_FORCE64=n
CONFIG_NR_CPUS=64

# Graphics - NVIDIA
CONFIG_DRM=nvidia
CONFIG_DRM_NOUVM=n
CONFIG_NV_TEGRA_COMBINATION=y
CONFIG_NVIDIA_DRM=y
CONFIG_NVIDIA_UVM=y
CONFIG_NVIDIA_UVM_SVM=y

# Graphics - AMD
CONFIG_DRM_AMDGPU=y
CONFIG_DRM_AMDGPU_USERPTR=y
CONFIG_DRM_AMD_ACP=y
CONFIG_AMD_IOMMU=y
CONFIG_AMD_IOMMU_V2=y
CONFIG_AMDGPU=y
CONFIG_AMDGPU_CIK=y
CONFIG_AMDGPU_CS=y
CONFIG_AMDGPU_DC=y
CONFIG_AMDGPU_SI=y
CONFIG_AMDGPU_TMZ=y

# Vulkan
CONFIG_VULKAN=y
CONFIG_VULKAN_AMD=y
CONFIG_VULKAN_INTEL=y
CONFIG_VULKAN_OVERLAY=y
CONFIG_MVK_VERSION=286

# Gaming
CONFIG_GAMEPORT=y
CONFIG_JOYSTICK=y
CONFIG_INPUT_JOYSTICK=y
CONFIG_JOYSTICK_XPAD=y
CONFIG_JOYSTICK_XPAD_FF=y
CONFIG_JOYSTICK_PXPAD5_FF=y
CONFIG_JOYSTICK_DRAGONRIS=y
CONFIG_JOYSTICK_WII_EXTENSION=y
CONFIG_JOYSTICK_USB_SENSOR=y
CONFIG_HIDRAW=y

# Bluetooth
CONFIG_BT=y
CONFIG_BT_RFCOMM=y
CONFIG_BT_RFCOMM_TTY=y
CONFIG_BT_BNEP=y
CONFIG_BT_CMTP=y
CONFIG_BT_HIDP=y
CONFIG_BT_HS=y
CONFIG_BT_LE=y
CONFIG_BT_LEDS=y

# Audio
CONFIG_SND_HDA_CORE=y
CONFIG_SND_HDA=y
CONFIG_SND_HDA_INTEL=y
CONFIG_SND_HDA_CODEC_REALTEK=y
CONFIG_SND_HDA_CODEC_HDMIX=y
CONFIG_SND_PCSP=y
CONFIG_SND_USB=y
CONFIG_SND_USB_AUDIO=y
CONFIG_SND_USB_UA101=y

# USB
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_UHCI_HCD=y

# Network
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IP_PNP=y
CONFIG_NET_DROP_MONITOR=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_BTRFS_FS=y
CONFIG_F2FS_FS=y
CONFIG_NTFS_FS=y
CONFIG_NTFS3_FS=y

# Memory
CONFIG_KSM=y
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_ZSWAP=y

# Security
CONFIG_SECURITY=y
CONFIG_SECURITY_NETWORK=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_SECURITY_SELINUX=n

# VMware support
CONFIG_VMWARE_BALLOON=y
CONFIG_VMWARE_VMCI=y
CONFIG_VMWARE_PVSCSI=y
CONFIG_VMWARE_NETWORK=y

# Container support
CONFIG_NAMESPACES=y
CONFIG_NET_NS=y
CONFIG_PID_NS=y
CONFIG_UTS_NS=y
CONFIG_USER_NS=y
CONFIG_CGROUPS=y
CONFIG_CPUSETS=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_FREEZER=y

# Overlay
CONFIG_OVERLAY_FS=y

# Performance
CONFIG_HARDEN_EL2_VECTORS=n
CONFIG_THIN_ARCHIVES=y
CONFIG_MODULES=y
CONFIG_MODULE_FORCE_LOAD=y
CONFIG_MODULE_COMPRESS=y